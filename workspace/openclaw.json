{
  // OpenClaw Configuration for Wholesale Real Estate Multi-Agent System
  // Copy to ~/.openclaw/openclaw.json and customize
  
  agents: {
    defaults: {
      model: "anthropic/claude-opus-4-6",
      workspace: "~/.openclaw/workspace",
      thinkingLevel: "high",
      models: {
        "anthropic/claude-opus-4-6": { alias: "Opus" },
        "anthropic/claude-sonnet-4-5": { alias: "Sonnet" },
        "openai/gpt-5.2": { alias: "GPT" },
      },
      // Orchestrator pattern: main agent can spawn specialized sub-agents
      subagents: {
        model: "anthropic/claude-sonnet-4-5",  // Cheaper model for worker agents
        maxSpawnDepth: 1,  // Allow orchestrator → workers
        allowAgents: ["*"],  // Allow spawning any of the agents below
        maxConcurrent: 5,  // Max 5 sub-agents at once
      },
      // Memory configuration using QMD for semantic search
      memorySearch: {
        enabled: true,
        provider: "openai",  // Uses OpenAI embeddings (requires API key)
        model: "text-embedding-3-small",
        fallback: "openai",
        sync: { watch: true },  // Auto-index on file changes
      },
    },
    list: [
      {
        id: "lead-scout",
        emoji: "🔍",
        workspace: "~/.openclaw/workspace",
        model: "anthropic/claude-sonnet-4-5",
        tools: {
          allow: ["browser", "read", "write", "sessions_spawn", "sessions_send", "memory_search", "memory_get"],
        },
      },
      {
        id: "market-analysis",
        emoji: "📊",
        workspace: "~/.openclaw/workspace",
        model: "anthropic/claude-sonnet-4-5",
        tools: {
          allow: ["browser", "read", "write", "sessions_spawn", "sessions_send", "memory_search", "memory_get"],
        },
      },
      {
        id: "acquisition",
        emoji: "🤝",
        workspace: "~/.openclaw/workspace",
        model: "anthropic/claude-sonnet-4-5",
        tools: {
          allow: ["browser", "read", "write", "sessions_spawn", "sessions_send", "message", "memory_search", "memory_get"],
        },
      },
      {
        id: "title-research",
        emoji: "📋",
        workspace: "~/.openclaw/workspace",
        model: "anthropic/claude-sonnet-4-5",
        tools: {
          allow: ["browser", "read", "write", "sessions_spawn", "sessions_send", "memory_search", "memory_get"],
        },
      },
      {
        id: "dispositions",
        emoji: "💰",
        workspace: "~/.openclaw/workspace",
        model: "anthropic/claude-sonnet-4-5",
        tools: {
          allow: ["browser", "read", "write", "sessions_spawn", "sessions_send", "message", "memory_search", "memory_get"],
        },
      },
      {
        id: "transaction-coord",
        emoji: "📝",
        workspace: "~/.openclaw/workspace",
        model: "anthropic/claude-sonnet-4-5",
        tools: {
          allow: ["browser", "read", "write", "sessions_spawn", "sessions_send", "memory_search", "memory_get"],
        },
      },
    ],
  },

  // QMD backend for local-first semantic search (alternative to OpenAI embeddings)
  // Install QMD: bun install -g https://github.com/tobi/qmd
  memory: {
    backend: "qmd",  // Use QMD for local-first BM25 + vector search
    citations: "auto",
    qmd: {
      includeDefaultMemory: true,
      update: { interval: "5m", debounceMs: 15000 },
      limits: { maxResults: 10, timeoutMs: 5000 },
      // Add your Obsidian vault or other note directories
      paths: [
        // { name: "obsidian", path: "~/Documents/Obsidian/MyVault", pattern: "**/*.md" },
        // { name: "deals", path: "~/.openclaw/workspace/deals", pattern: "**/*.md" },
      ],
    },
  },

  channels: {
    whatsapp: {
      enabled: true,
      dmPolicy: "allowlist",
      allowFrom: [],
    },
    telegram: {
      enabled: true,
      botToken: "YOUR_TELEGRAM_BOT_TOKEN",
      dmPolicy: "allowlist",
      allowFrom: [],
    },
    discord: { enabled: false },
    signal: { enabled: false },
  },

  browser: {
    enabled: true,
    defaultProfile: "openclaw",
    color: "#FF4500",
  },

  tools: {
    browser: { enabled: true },
    sessions: { enabled: true },
    cron: { enabled: true },
    webhook: { enabled: true },
    memory: { enabled: true },  // Enable memory tools
  },

  automation: {
    cron: [
      // === DEAL PIPELINE AUTOMATION ===
      {
        id: "stale-deal-check",
        schedule: "0 8 * * *",  // Daily at 8 AM
        session: "main",
        message: "Check all deals in the pipeline for stale status. Alert on deals stuck in 'contacted' >3 days, 'under-contract' >7 days, or 'marketing' >5 days. Suggest follow-up actions.",
      },
      {
        id: "pipeline-summary",
        schedule: "0 18 * * *",  // Daily at 6 PM
        session: "main",
        message: "Summarize today's pipeline activity: new leads, status changes, deals closed. Write summary to memory.",
      },
      
      // === LEAD GENERATION AUTOMATION ===
      {
        id: "morning-zillow-scan",
        schedule: "0 7 * * *",  // Daily at 7 AM
        session: "main",
        message: "Scan Zillow for new listings and price drops in target ZIP codes. Filter by: under $300K, listed >30 days, or price reduced >10%. Create new deal files for matches.",
      },
      {
        id: "county-records-check",
        schedule: "0 9 * * 1",  // Weekly Monday 9 AM
        session: "main",
        message: "Check county records for new distress indicators: tax delinquent properties, code violations, probate filings, and pre-foreclosures in target areas.",
      },
      {
        id: "expired-listings-check",
        schedule: "0 10 * * *",  // Daily at 10 AM
        session: "main",
        message: "Check for recently expired MLS listings in target ZIP codes. These are motivated sellers who tried to sell but failed. Create leads for follow-up.",
      },
      {
        id: "price-drop-alerts",
        schedule: "0 */4 * * *",  // Every 4 hours
        session: "main",
        message: "Check watched properties for price drops. Alert if any property drops below our MAO threshold.",
      },
      
      // === FOLLOW-UP REMINDERS ===
      {
        id: "seller-follow-up",
        schedule: "0 10 * * *",  // Daily at 10 AM
        session: "main",
        message: "Review all deals in 'contacted' status. Identify sellers who haven't been contacted in 3+ days. Suggest follow-up messages.",
      },
      {
        id: "buyer-outreach",
        schedule: "0 14 * * 3",  // Wednesday 2 PM
        session: "main",
        message: "Review deals in 'marketing' status. Check if all qualified buyers have been contacted. Suggest additional outreach if needed.",
      },
    ],
  },

  gateway: {
    port: 18789,
    bind: "loopback",
    mode: "local",
  },

  security: {
    sandbox: { mode: "non-main" },
  },

  logging: { level: "info" },
}
