{
  // OpenClaw Configuration for Wholesale Real Estate Multi-Agent System
  // Copy to ~/.openclaw/openclaw.json and customize
  
  agents: {
    defaults: {
      model: "anthropic/claude-opus-4-6",
      workspace: "~/.openclaw/workspace",
      thinkingLevel: "high",
      models: {
        "anthropic/claude-opus-4-6": { alias: "Opus" },
        "anthropic/claude-sonnet-4-5": { alias: "Sonnet" },
        "openai/gpt-5.2": { alias: "GPT" },
      },
    },
  },

  channels: {
    whatsapp: {
      enabled: true,
      dmPolicy: "allowlist",
      allowFrom: [],
    },
    telegram: {
      enabled: true,
      botToken: "YOUR_TELEGRAM_BOT_TOKEN",
      dmPolicy: "allowlist",
      allowFrom: [],
    },
    discord: { enabled: false },
    signal: { enabled: false },
  },

  browser: {
    enabled: true,
    defaultProfile: "openclaw",
    color: "#FF4500",
  },

  tools: {
    browser: { enabled: true },
    sessions: { enabled: true },
    cron: { enabled: true },
    webhook: { enabled: true },
  },

  automation: {
    cron: [
      {
        id: "morning-lead-scan",
        schedule: "0 8 * * *",
        session: "main",
        message: "Run morning lead scan for new properties",
      },
    ],
  },

  gateway: {
    port: 18789,
    bind: "loopback",
    mode: "local",
  },

  security: {
    sandbox: { mode: "non-main" },
  },

  logging: { level: "info" },
}
