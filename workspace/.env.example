# Wholesaile Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to ~/.openclaw/.env and fill in your values.
# OpenClaw automatically loads ~/.openclaw/.env at startup.
#
# Usage in openclaw.json: reference as ${VARIABLE_NAME}
# Example: "botToken": "${TELEGRAM_BOT_TOKEN}"
# ─────────────────────────────────────────────────────────────────────────────

# ═══════════════════════════════════════════════════════════════
# AI MODEL PROVIDERS (at least one required)
# ═══════════════════════════════════════════════════════════════

# Anthropic (recommended — used for Claude Opus/Sonnet)
# Get key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI (optional — used for GPT models)
# Get key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ═══════════════════════════════════════════════════════════════
# MESSAGING CHANNELS (configure at least one)
# ═══════════════════════════════════════════════════════════════

# Telegram Bot
# 1. Message @BotFather on Telegram
# 2. Send /newbot and follow instructions
# 3. Copy the token here
TELEGRAM_BOT_TOKEN=

# WhatsApp Business API (Meta)
# Get from: https://developers.facebook.com/apps/
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=

# Signal (via signal-cli)
# Your Signal phone number in E.164 format
SIGNAL_PHONE_NUMBER=

# ═══════════════════════════════════════════════════════════════
# GATEWAY SECURITY
# ═══════════════════════════════════════════════════════════════

# Gateway auth token (auto-generated if not set)
# Used to authenticate webhook calls and API requests
# Generate with: openssl rand -hex 32
OPENCLAW_GATEWAY_TOKEN=

# ═══════════════════════════════════════════════════════════════
# SKIP TRACING (optional — for finding owner contact info)
# ═══════════════════════════════════════════════════════════════

# BatchSkipTracing — https://batchskiptracing.com/
BATCH_SKIP_TRACING_API_KEY=

# SkipGenie — https://skipgenie.com/
SKIP_GENIE_API_KEY=

# TisoM — https://tisom.com/
TISOM_API_KEY=

# ═══════════════════════════════════════════════════════════════
# CRM INTEGRATION (optional — for contact management)
# ═══════════════════════════════════════════════════════════════

# GoHighLevel — https://www.gohighlevel.com/
GHL_API_KEY=
GHL_LOCATION_ID=

# HubSpot — https://www.hubspot.com/
HUBSPOT_API_KEY=

# ═══════════════════════════════════════════════════════════════
# PROPERTY DATA (optional — for automated comp analysis)
# ═══════════════════════════════════════════════════════════════

# Estated Property API — https://estated.com/
ESTATED_API_KEY=

# Realtor.com API — https://www.realtor.com/api/
REALTOR_API_KEY=

# ═══════════════════════════════════════════════════════════════
# NOTIFICATIONS (optional)
# ═══════════════════════════════════════════════════════════════

# Twilio (for SMS notifications)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
